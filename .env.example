# =============================================================================
# Environment variables — copy this file to `.env.local` and fill in the values.
# .env.local is git-ignored; the file you commit is .env.example (this one).
#
# In production, set these in the Vercel dashboard. In CI, set them as
# GitHub Actions repo secrets.
# =============================================================================

# ---- Supabase ---------------------------------------------------------------
# Get these from: Supabase dashboard → your project → Settings → API.
# Use the DEV project values in .env.local and the PROD ones in Vercel.

# Public — safe to ship to the browser. Used by client and server.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only — NEVER expose to the browser. Used for admin operations
# (member provisioning, audit-trail reads, etc.) that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase CLI project refs (the slug in your project URL, the part before
# .supabase.co). Used by `pnpm db:link:dev` and `pnpm db:link:prod`.
SUPABASE_PROJECT_REF_DEV=your-dev-project-ref
SUPABASE_PROJECT_REF_PROD=your-prod-project-ref


# ---- Anthropic (Phase 4+, not needed for Phase 1) --------------------------
# ANTHROPIC_API_KEY=sk-ant-...


# ---- GitHub (Phase 2+ for the SCL integration, not needed for Phase 1) -----
# GITHUB_WEBHOOK_SECRET=...
# GITHUB_APP_PRIVATE_KEY=...


# ---- Auth -------------------------------------------------------------------
# The single email allowed to use the app in Phase 1. Must match the account
# you created manually in Supabase (Authentication → Users). Server-only —
# do NOT prefix with NEXT_PUBLIC_. Set this in Vercel and CI too.
ALLOWED_EMAIL=you@example.com


# ---- App URLs ---------------------------------------------------------------
# Used by Supabase Auth as the password-reset redirect target. Set this to your
# real deploy URL in Vercel; localhost is fine for `pnpm dev`.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
